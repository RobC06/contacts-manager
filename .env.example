# MongoDB Connection String
# For MongoDB Atlas, get this from your cluster's "Connect" button
# For local development, use: mongodb://localhost:27017/contact-outreach-manager
MONGODB_URI=your_mongodb_connection_string_here

# Session Secret (change this to a random string in production)
SESSION_SECRET=your_random_secret_key_here

# Node Environment
NODE_ENV=production

# Port (Railway will set this automatically, but you can specify for local dev)
PORT=3000
